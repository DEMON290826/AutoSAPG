{
  "name": "autosapg",
  "private": true,
  "version": "1.0.0",
  "description": "AutoSAPG desktop app",
  "author": "doran",
  "repository": {
    "type": "git",
    "url": "https://github.com/doran/AutoSAPG.git"
  },
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "electron:start": "npm run build && set ELECTRON_RUN_AS_NODE=&& electron .",
    "electron:pack": "npm run build && set ELECTRON_RUN_AS_NODE=&& electron-builder --win nsis --config.win.signAndEditExecutable=false",
    "electron:pack:setup": "npm run build && set ELECTRON_RUN_AS_NODE=&& electron-builder --win nsis --config.win.signAndEditExecutable=false",
    "electron:pack:portable": "npm run build && set ELECTRON_RUN_AS_NODE=&& electron-builder --win portable --config.win.signAndEditExecutable=false",
    "electron:release:github": "npm run build && set ELECTRON_RUN_AS_NODE=&& electron-builder --win nsis --publish always --config.win.signAndEditExecutable=false"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.6.2",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "playwright-core": "^1.58.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.doran.autosapg",
    "productName": "AutoSAPG",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icons/app-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "AutoSAPG",
      "installerIcon": "build/icons/app-icon.ico",
      "uninstallerIcon": "build/icons/app-icon.ico"
    },
    "extraResources": [
      {
        "from": "build/icons",
        "to": "build/icons"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "DEMON290826",
        "repo": "AutoSAPG",
        "releaseType": "release"
      }
    ]
  }
}
